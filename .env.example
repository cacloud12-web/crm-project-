# WHATSAPP_TASK_DOCUMENT_URL=https://your-domain.com/docs/task-notification.pdf
# WHATSAPP_TASK_DOCUMENT_FILENAME=task-notification.pdf
# WHATSAPP_INVOICE_DOCUMENT_URL=https://your-domain.com/docs/invoice.pdf
# WHATSAPP_INVOICE_DOCUMENT_FILENAME=invoice.pdf

# Production deploy checklist:
# 1. APP_ENV=production  APP_DEBUG=false  APP_KEY=<php artisan key:generate>
# 2. php artisan migrate --force && php artisan db:seed --force  (first deploy only)
# 3. php artisan storage:link
# 4. Background jobs (email campaigns, bulk import):
#    Option A — QUEUE_CONNECTION=sync (no worker; jobs run inline during HTTP/scheduler)
#    Option B — CRM_QUEUE_AUTO_DRAIN=true + php artisan schedule:work (local) or cron schedule:run
#    Option C — Production: dedicated Supervisor queue worker (see docs/QUEUE_OPERATIONS.md)
# 5. IMAP inbox auto-sync (every 5 min via scheduler):
#    cron * * * * * php artisan schedule:run
#    Local dev alternative: php artisan schedule:work
#    (The Inbox UI also auto-polls every 5 min while Communication → Email is open.)
# 6. php artisan optimize
CRM_QUEUE_AUTO_DRAIN=true
#
# IMAP inbox sync (no queue worker required for Sync Latest Emails button):
# CRM_IMAP_SYNC_QUICK_LIMIT=25
# CRM_INBOX_AUTO_SYNC_MINUTES=5
#
# Google Maps + Places (one key can be used for both):
# Backend Places API (server-side only — IP or no app restrictions):
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=
# Frontend Maps JavaScript API only (HTTP referrer restrictions):
VITE_GOOGLE_MAPS_API_KEY=

# Google Document AI OCR
# Document AI is the OCR engine itself — no separate Tesseract/OCR library or AIza API key is needed.
# You still need: project ID, processor ID, location, and server auth (service-account JSON or ADC).
GOOGLE_DOCUMENT_AI_PROJECT_ID=
GOOGLE_DOCUMENT_AI_LOCATION=us
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
# Optional explicit Document AI credentials path. If empty, falls back to GOOGLE_APPLICATION_CREDENTIALS or ADC.
GOOGLE_DOCUMENT_AI_CREDENTIALS=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_DOCUMENT_AI_TIMEOUT=120
# Absolute upload ceiling (prefer >= batch max so large PDFs can upload for batch OCR).
GOOGLE_DOCUMENT_AI_MAX_FILE_MB=100
GOOGLE_DOCUMENT_AI_ONLINE_MAX_PAGES=30
GOOGLE_DOCUMENT_AI_BATCH_MAX_PAGES=500
GOOGLE_DOCUMENT_AI_ONLINE_MAX_FILE_MB=40
GOOGLE_DOCUMENT_AI_BATCH_MAX_FILE_MB=1024
GOOGLE_DOCUMENT_AI_BATCH_POLL_SECONDS=10
GOOGLE_DOCUMENT_AI_BATCH_TIMEOUT_MINUTES=60
GOOGLE_DOCUMENT_AI_SYNC_SMALL_FILES=true
GOOGLE_DOCUMENT_AI_SYNC_MAX_PAGES=5
GOOGLE_DOCUMENT_AI_SYNC_MAX_FILE_MB=5
GOOGLE_DOCUMENT_AI_SYNC_TIMEOUT_SECONDS=60

# Required for large-document (batch) OCR — private buckets only.
GOOGLE_CLOUD_STORAGE_INPUT_BUCKET=
GOOGLE_CLOUD_STORAGE_OUTPUT_BUCKET=
GOOGLE_CLOUD_STORAGE_INPUT_PREFIX=ocr-input
GOOGLE_CLOUD_STORAGE_OUTPUT_PREFIX=ocr-output
GOOGLE_OCR_DELETE_GCS_INPUT_AFTER_SUCCESS=true
GOOGLE_OCR_DELETE_GCS_OUTPUT_AFTER_SUCCESS=false
GOOGLE_OCR_GCS_RETENTION_DAYS=7

