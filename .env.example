APP_NAME="CA Cloud Desk CRM"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Optional: env-driven bootstrap (prefer: php artisan crm:create-super-admin)
# CRM_ROOT_SUPER_ADMIN_EMAIL=
# CRM_ROOT_SUPER_ADMIN_NAME="Super Admin"
# CRM_ROOT_SUPER_ADMIN_PASSWORD=

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=crm_project
DB_USERNAME=postgres
DB_PASSWORD=

# PostgreSQL source (retain for rollback until MySQL is verified)
PGSQL_HOST=127.0.0.1
PGSQL_PORT=5432
PGSQL_DATABASE=crm_project
PGSQL_USERNAME=postgres
PGSQL_PASSWORD=

# MySQL target — set before: php artisan crm:migrate-pg-to-mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=crm_project
MYSQL_USERNAME=root
MYSQL_PASSWORD=
MYSQL_ADMIN_HOST=127.0.0.1
MYSQL_ADMIN_PORT=3306
MYSQL_ADMIN_USERNAME=root
MYSQL_ADMIN_PASSWORD=

# CA Reference Database (secondary connection — MariaDB on Hostinger)
# Separate CA Reference Database (MySQL). Do not set CA_REFERENCE_DB_DRIVER in production (defaults to mysql).
# Import official Excel/CSV (not OCR):
#   php artisan migrate --database=ca_reference --path=database/migrations/ca_reference --force
#   php artisan ca-reference:import /path/to/file.xlsx --dry-run
#   php artisan ca-reference:import /path/to/file.xlsx --chunk=1000
# Never run: php artisan migrate --database=ca_reference  (without --path) — blocked by guard.
# Cleanup accidental CRM tables (dry-run first):
#   php artisan ca-reference:backup-schema
#   php artisan ca-reference:cleanup-accidental-tables --dry-run
#   php artisan ca-reference:cleanup-accidental-tables --execute
CA_REFERENCE_DB_HOST=
CA_REFERENCE_DB_PORT=3306
CA_REFERENCE_DB_DATABASE=
CA_REFERENCE_DB_USERNAME=
CA_REFERENCE_DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=lepe eswk jtut uvib
MAIL_FROM_ADDRESS=cacloud12@gmail.com
MAIL_FROM_NAME=ca cloud desk

# CRM SMTP (cloud desk / GoDaddy) — used when seeding email_settings
SMTP_PROVIDER_NAME="cloud desk"
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_USERNAME="CRM Email"
SMTP_PASSWORD=lepe eswk jtut uvib
SMTP_ENCRYPTION=tls
SMTP_FROM_EMAIL=cacloud12@gmail.com
SMTP_FROM_NAME="CA Cloud Desk"
SMTP_REPLY_TO_EMAIL=cacloud12@gmail.com
SMTP_MODE=live
EMAIL_SKIP_MX_CHECK=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# CRM production thresholds (optional)
# CRM_IMPORT_SYNC_ROW_LIMIT=100
# CRM_CAMPAIGN_LOG_SYNC_LIMIT=50
# CRM_REPORT_EXPORT_SYNC_ROW_LIMIT=500
# CRM_LOGIN_MAX_ATTEMPTS=5
